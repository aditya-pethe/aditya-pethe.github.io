---
interface Props {
  color?: 'blue' | 'pink' | 'lavender' | 'neutral';
  class?: string;
}
const { color = 'neutral', class: cls } = Astro.props;
---
<span class:list={['tag', `tag--${color}`, cls]}><slot /></span>

<style>
  .tag {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 13px;
    padding: 4px 10px;
    border-radius: var(--radius-sm);
  }
  .tag--blue { background: var(--accent-bg); color: var(--accent-text); }
  .tag--pink { background: var(--pink-bg); color: var(--pink-text); }
  .tag--lavender { background: var(--lavender-bg); color: var(--lavender-text); }
  .tag--neutral { background: var(--surface-1); color: var(--text-secondary); border: 1px solid var(--border); }
</style>
