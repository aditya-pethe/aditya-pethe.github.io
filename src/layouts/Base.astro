---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = `${site.name} — ${site.role}`,
  description = 'Data scientist and machine learning engineer. Ranking, recommendation, and applied ML.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#0B0F12" />
    <link rel="canonical" href={Astro.site?.href} />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var theme = stored ||
            (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body>
    <header class="nav">
      <div class="container nav__inner">
        <a href="/" class="wordmark">{site.name}</a>
        <nav class="nav__links" aria-label="Primary">
          <a href="/#about" data-spy>About</a>
          <a href="/#experience" data-spy>Experience</a>
          <a href="/#contact" data-spy>Contact</a>
        </nav>
        <ThemeToggle />
      </div>
    </header>

    <div class="social-bar">
      <div class="container social-bar__inner">
        <a href={site.socials.github} class="social" target="_blank" rel="noopener" aria-label="GitHub"><Icon name="github" size={20} /></a>
        <a href={site.resumePdf} class="social" target="_blank" rel="noopener" aria-label="Résumé"><Icon name="file" size={20} /></a>
        <a href={site.socials.linkedin} class="social" target="_blank" rel="noopener" aria-label="LinkedIn"><Icon name="linkedin" size={20} /></a>
        <a href={site.socials.twitter} class="social" target="_blank" rel="noopener" aria-label="X (Twitter)"><Icon name="x" size={18} /></a>
      </div>
    </div>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container footer__inner">
        <span>© {new Date().getFullYear()} {site.name}</span>
        <span class="footer__links">
          <a href={site.socials.github}>GitHub</a>
          <a href={site.socials.linkedin}>LinkedIn</a>
          <a href={`mailto:${site.email}`}>Email</a>
        </span>
      </div>
    </footer>

    <style>
      .nav {
        position: sticky;
        top: 0;
        z-index: 10;
        background: color-mix(in srgb, var(--surface-0) 88%, transparent);
        backdrop-filter: saturate(1.2) blur(8px);
        border-bottom: 1px solid var(--border);
      }
      .nav__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-6);
        padding-block: var(--space-4);
      }
      .wordmark {
        font-family: var(--font-display);
        font-weight: 600;
        font-size: 18px;
        letter-spacing: -0.01em;
        color: var(--text-primary);
      }
      .wordmark:hover { color: var(--text-primary); }
      .nav__links {
        display: flex;
        align-items: center;
        gap: var(--space-6);
        margin-left: auto;
        font-size: 14px;
        font-weight: 500;
      }
      .nav__links a { color: var(--text-secondary); }
      .nav__links a:hover { color: var(--text-primary); }
      .nav__links a[data-spy] {
        padding-bottom: 3px;
        border-bottom: 2px solid transparent;
        transition: color var(--duration-fast) var(--ease-standard),
          border-color var(--duration-fast) var(--ease-standard);
      }
      .nav__links a[data-spy].is-active {
        color: var(--text-primary);
        border-bottom-color: var(--text-primary);
      }
      .social-bar__inner {
        display: flex;
        gap: var(--space-1);
        padding-top: var(--space-6);
      }
      .social {
        width: 40px;
        height: 40px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: var(--radius);
        color: var(--text-secondary);
        border: 1px solid transparent;
        transition: color var(--duration-fast) var(--ease-standard),
          background var(--duration-fast) var(--ease-standard);
      }
      .social:hover { color: var(--text-primary); background: var(--surface-1); }

      .footer {
        border-top: 1px solid var(--border);
        margin-top: var(--space-24);
      }
      .footer__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-4);
        padding-block: var(--space-8);
        font-size: 13px;
        color: var(--text-muted);
      }
      .footer__links { display: flex; gap: var(--space-5); }
      .footer__links a { color: var(--text-muted); }
      .footer__links a:hover { color: var(--text-primary); }

      @media (max-width: 640px) {
        .nav__links a:not(.nav__resume) { display: none; }
        .footer__inner { flex-direction: column; align-items: flex-start; }
      }
    </style>

    <script is:inline>
      (function () {
        var links = Array.prototype.slice.call(
          document.querySelectorAll('.nav__links a[data-spy]')
        );
        if (!links.length) return;
        var sections = links.map(function (l) {
          var id = (l.getAttribute('href') || '').split('#')[1];
          return id ? document.getElementById(id) : null;
        });

        function setActive(link) {
          links.forEach(function (l) {
            l.classList.toggle('is-active', l === link);
          });
        }
        function topOf(el) {
          return el.getBoundingClientRect().top + window.scrollY;
        }
        function onScroll() {
          // bottom of page -> last section active
          if (window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 2) {
            setActive(links[links.length - 1]);
            return;
          }
          var pos = window.scrollY + 140; // offset for sticky nav
          var current = -1;
          for (var i = 0; i < sections.length; i++) {
            if (sections[i] && topOf(sections[i]) <= pos) current = i;
          }
          setActive(current >= 0 ? links[current] : null);
        }

        // Instant feedback on click; scroll settles it afterward.
        links.forEach(function (l) {
          l.addEventListener('click', function () { setActive(l); });
        });
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll);
        onScroll();
      })();
    </script>
  </body>
</html>
